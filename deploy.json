{
  "port": 443,
  "ports": ["80:80", "443:443"],
  "docker_socket": true,
  "registers": false,
  "placement": ["any"],
  "repo": "TelosHephaestusHQ/traefik",
  "secrets": ["DYNADOT_API_KEY", "DYNADOT_API_SECRET"],
  "volumes": [
    {"host": "/data/traefik/acme", "container": "/acme"}
  ],
  "healthcheck": {
    "type": "http",
    "target": "/ping"
  }
}
